DASH_TOKEN=26028058835026d0fbffa819883240104f4f46dd5b04b1c7
# Health Auto Export 앱의 api-key 헤더 값 (openssl rand -hex 24)
HEALTH_INGEST_TOKEN=64e5b60cc8db14e83837aab14059952d2427d1f9457be3c7
# GitHub PAT (read:user) — Phase 2
GITHUB_TOKEN=
GITHUB_USERNAME=kobums
# GitLab PAT (read_api) — Phase 2
