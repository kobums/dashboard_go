# 서버 /data/dashboard/.env 에 복사해 값 채우기.
# global/config/config.go 의 환경변수 오버라이드가 .env.yml(production) 값을 덮어쓴다.
APP_MODE=production
DB_HOST=mariadb
DB_PORT=3306
DB_NAME=dashboard
DB_USER=dashboard
DB_PASS=dashboarddb
